{
  "name": "rihla",
  "private": true,
  "version": "1.0.0",
  "description": "Rihla — Gestion d'agence de voyage",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:lan": "concurrently \"npm run dev:server\" \"vite --host\"",
    "dev:server": "npm run dev --prefix server",
    "build": "vite build",
    "preview": "vite preview",
    "start:server": "npm run start --prefix server",
    "start:local": "npm run build && NODE_ENV=production npm run start:server",
    "seed:demo": "npm run seed:demo --prefix server",
    "archive": "bash scripts/creer-archive.sh"
  },
  "dependencies": {
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.2",
    "recharts": "^2.13.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.11",
    "vite": "^5.4.3"
  }
}
